<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Dreamscape.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dreamscape.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#f5f5f5">

        <!-- Background -->
        <Grid>
            <Rectangle Fill="#f5f5f5"/>
            <Rectangle Fill="#000000" Opacity="0.02"/>
        </Grid>

        <Border Width="600"
                Padding="50"
                CornerRadius="20"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#e5e5e5"
                BorderThickness="1">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <StackPanel Spacing="30">

                <!-- Title -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="DREAMSCAPE"
                               FontSize="30"
                               FontWeight="SemiBold"
                               CharacterSpacing="200"/>

                    <TextBlock Text="PLAYER PLATFORM"
                               FontSize="12"
                               Foreground="#777"
                               CharacterSpacing="150"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#eeeeee"/>

                <!-- Buttons -->

                <Button Content="ITEM CATALOG"
                        Click="Catalog_Click"
                        Height="55"
                        Background="Black"
                        Foreground="White"
                        CornerRadius="12"
                        FontWeight="SemiBold"
                        CharacterSpacing="100"/>

                <Button Content="TRADE ITEMS"
                        Click="Trade_Click"
                        Height="55"
                        Background="#f0f0f0"
                        Foreground="Black"
                        CornerRadius="12"
                        BorderBrush="#dddddd"/>

                <Button Content="INVENTORY"
                        Click="Inventory_Click"
                        Height="55"
                        Background="#f0f0f0"
                        Foreground="Black"
                        CornerRadius="12"
                        BorderBrush="#dddddd"/>

                <Button Content="MY PROFILE"
                        Click="Profile_Click"
                        Height="55"
                        Background="#f0f0f0"
                        Foreground="Black"
                        CornerRadius="12"
                        BorderBrush="#dddddd"/>

                <Button Content="LOGOUT"
                        Click="Logout_Click"
                        Height="50"
                        Background="#e5e5e5"
                        Foreground="Black"
                        CornerRadius="12"/>

            </StackPanel>

        </Border>

    </Grid>

</Page>