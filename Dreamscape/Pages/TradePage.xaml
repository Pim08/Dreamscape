<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Dreamscape.Pages.TradePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dreamscape.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#f5f5f5">

        <Border Width="500"
                Padding="40"
                CornerRadius="20"
                Background="White"
                BorderBrush="#e5e5e5"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="20">

                <TextBlock Text="SEND TRADE"
                           FontSize="26"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"/>

                <ComboBox x:Name="UserCombo"
                          Header="Select Player"/>

                <ComboBox x:Name="ItemCombo"
                          Header="Item you offer"/>

                <ComboBox x:Name="RequestCombo"
                          Header="Item you want"/>

                <Button Content="Send Trade"
                        Click="SendTrade_Click"
                        Height="45"
                        Background="Black"
                        Foreground="White"
                        CornerRadius="10"/>

            </StackPanel>

        </Border>

    </Grid>

</Page>