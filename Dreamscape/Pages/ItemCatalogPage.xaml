<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Dreamscape.Pages.ItemCatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dreamscape.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#f5f5f5">

        <Border Width="900"
                Padding="40"
                CornerRadius="20"
                Background="White"
                BorderBrush="#e5e5e5"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <StackPanel Spacing="20">

                <TextBlock Text="ITEM CATALOG"
                           FontSize="28"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"/>

                <ListView x:Name="ItemList">

                    <ListView.ItemTemplate>

                        <DataTemplate>

                            <Border Padding="15"
                                    Margin="0,5"
                                    CornerRadius="10"
                                    Background="#fafafa"
                                    BorderBrush="#e5e5e5"
                                    BorderThickness="1">

                                <StackPanel>

                                    <TextBlock Text="{Binding Naam}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Beschrijving}"
                                               FontSize="13"
                                               Foreground="Gray"/>

                                    <StackPanel Orientation="Horizontal" Spacing="20">

                                        <TextBlock>
                                            <Run Text="Kracht: "/>
                                            <Run Text="{Binding Kracht}"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Snelheid: "/>
                                            <Run Text="{Binding Snelheid}"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Duurzaamheid: "/>
                                            <Run Text="{Binding Duurzaamheid}"/>
                                        </TextBlock>

                                    </StackPanel>

                                    <TextBlock Text="{Binding MagischeEigenschap}"
                                               Foreground="DarkRed"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ListView.ItemTemplate>

                </ListView>

            </StackPanel>

        </Border>

    </Grid>

</Page>