<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Dreamscape.Pages.ItemCatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dreamscape.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#f5f5f5">

        <Border Width="900"
                Padding="40"
                CornerRadius="20"
                Background="White"
                BorderBrush="#e5e5e5"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <StackPanel Spacing="20">

                <TextBlock Text="ITEM CATALOG"
                           FontSize="28"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"/>

                <!-- Fire Search Box -->
                <Border Background="#f8f8f8"
                        CornerRadius="15"
                        BorderBrush="#ddd"
                        BorderThickness="2"
                        Padding="15,10">
                    
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Search Icon -->
                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE721;"
                                  FontSize="20"
                                  Foreground="#666"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        
                        <!-- Search TextBox -->
                        <TextBox Grid.Column="1"
                                 x:Name="SearchBox"
                                 PlaceholderText="Search items by name, type, or magical property..."
                                 TextChanged="SearchBox_TextChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="15"
                                 VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Button Content="Home"
                        Click="Logout_Click"
                        Height="50"
                        Background="#e5e5e5"
                        Foreground="Black"
                        CornerRadius="12"/>

                <ListView x:Name="ItemList">

                    <ListView.ItemTemplate>

                        <DataTemplate>

                            <Border Padding="15"
                                    Margin="0,5"
                                    CornerRadius="10"
                                    Background="#fafafa"
                                    BorderBrush="#e5e5e5"
                                    BorderThickness="1">

                                <StackPanel>

                                    <TextBlock Text="{Binding Naam}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Beschrijving}"
                                               FontSize="13"
                                               Foreground="Gray"/>

                                    <StackPanel Orientation="Horizontal" Spacing="20">

                                        <TextBlock>
                                            <Run Text="Kracht: "/>
                                            <Run Text="{Binding Kracht}"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Snelheid: "/>
                                            <Run Text="{Binding Snelheid}"/>
                                        </TextBlock>
                                        <TextBlock>
                                            <Run Text="Duurzaamheid: "/>
                                            <Run Text="{Binding Duurzaamheid}"/>
                                        </TextBlock>

                                    </StackPanel>

                                    <TextBlock Text="{Binding MagischeEigenschap}"
                                               Foreground="DarkRed"/>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ListView.ItemTemplate>

                </ListView>

            </StackPanel>

        </Border>

    </Grid>

</Page>