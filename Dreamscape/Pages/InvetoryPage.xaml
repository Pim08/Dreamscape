<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Dreamscape.Pages.InvetoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Dreamscape.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#f5f5f5">

        <Border Width="800"
                Padding="40"
                CornerRadius="20"
                Background="White"
                BorderBrush="#e5e5e5"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>

            <StackPanel Spacing="20">

                <TextBlock Text="MY INVENTORY"
                           FontSize="28"
                           FontWeight="SemiBold"
                           CharacterSpacing="200"/>

                <ListView x:Name="InventoryList"

                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Margin="0,-15,0,5">

                    <ListView.ItemTemplate>

                        <DataTemplate>

                            <Border Padding="15"
                                    Margin="0,5"
                                    CornerRadius="10"
                                    Background="#fafafa"
                                    BorderBrush="#e5e5e5"
                                    BorderThickness="1">

                                <StackPanel>

                                    <TextBlock Text="{Binding Item.Naam}"
                                               FontSize="18"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Item.Beschrijving}"
                                               Foreground="Gray"/>

                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Aantal:"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Quantity}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </ListView.ItemTemplate>

                </ListView>

                <Button Content="BACK"
                        Click="Back_Click"
                        Height="50"
                        Background="#e5e5e5"
                        Foreground="Black"
                        CornerRadius="12"/>

            </StackPanel>

        </Border>

    </Grid>

</Page>
